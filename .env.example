# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- NetBox ---
NETBOX_URL=http://localhost:8000/api
NETBOX_TOKEN=__your_netbox_api_token__
CLUSTER_ID=1
SITE_ID=1
NETBOX_SITE_NAME=Home Lab
NETBOX_SITE_SLUG=home-lab

# --- Proxmox VE (API token auth) ---
PROXMOX_HOST=https://proxmox.example.com:8006
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=root@pam!netbox-sync
PROXMOX_TOKEN_SECRET=__your_proxmox_token_secret__

# --- UniFi (optional: wireless LANs, switch ports, MAC correlation) ---
# Integration API key (UniFi Network application).
UNIFI_HOST=unifi.example.com
UNIFI_PORT=11443
UNIFI_VERIFY_SSL=false
UNIFI_API_KEY=__your_unifi_api_key__
UNIFI_LEGACY_SITE=default

# --- iDRAC / Redfish (optional: Track B node hardware enrichment, --idrac) ---
# Creds also accepted via ~/.idrac-credentials (one line "user:pass", mode 600).
IDRAC_HOST=192.0.2.10
IDRAC_USER=__idrac_user__
IDRAC_PASS=__idrac_password__

# --- Optional static node facts (Track A; seeds hardware data the Proxmox API
#     can't provide). Leave blank to rely on live iDRAC (--idrac) instead. ---
NODE_SERIAL=
NODE_SERVICE_TAG=
NODE_BIOS_VERSION=
NODE_IDRAC_FIRMWARE=

# --- VM removal lifecycle (reaper) thresholds, in days ---
REAP_OFFLINE_DAYS=2
REAP_DECOM_DAYS=14
REAP_DELETE_DAYS=30

# --- Optional: path to your VLAN/subnet map (see prefixes.example.json) ---
# PREFIXES_FILE=/opt/netbox-sync/prefixes.json
